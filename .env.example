# ABICO Loyalty System

# Supabase: Transaction pooler URL (port 6543) - Vercel serverless-д ашиглана
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase: Direct connection URL (port 5432) - prisma migrate-д ашиглана
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

AUTH_SECRET="change-this-in-production-use-long-random-string"

# Resend: нууц үг сэргээх имэйл илгээхэд ашиглана — https://resend.com/api-keys
# Тохируулаагүй бол build/сервер унахгүй, харин "Нууц үг мартсан" имэйл бодитоор илгээгдэхгүй
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="ABICO Loyalty <onboarding@resend.dev>"

# Reset-password линкэд ашиглах домайн (production дээр жинхэнэ URL-ээр солих)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
